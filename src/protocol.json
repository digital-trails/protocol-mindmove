{
  "summary": {
    "icon": {
      "url": "/assets/logo3.png",
      "tint": false
    },
    "title": "Mind in Motion",
    "description": "Calm the mind. Move the body"
  },
  "home": {
    "element": {
      "type": "list",
      "elements": [
        {
          "type": "alert",
          "title": "Mind Move",
          "message": "Link movement and mental health",
          "icon": "/assets/logo1.png"
        },
        {
          "type": "devices",
          "summary": [
            {
              "device_id": "device_1",
              "text": "Oura Ring",
              "icon": {
                "url": "/assets/oura.png"
              }
            }
          ]
        },
        {
          "type": "carousel",
          "title": "Courses from headspace",
          "actions": [
            {
              "text": "Meditation Basics",
              "icon": {
                "url": "/assets/001-medicine.png",
                "tint": false
              },
              "action": "https://hdsp.co/share/681b905c676f43eaa24fb490",
              "backgroundcolor": "#FFA726",
              "markcompletedonclick": true
            },
            {
              "text": "Sports|Recovery",
              "icon": {
                "url": "/assets/020-person.png",
                "tint": false
              },
              "action": "https://hdsp.co/share/681baa3bb7ef4f17b820ccf6",
              "backgroundcolor": "#51CF66",
              "markcompletedonclick": true
            },
            {
              "text": "Sports|Rehab",
              "icon": {
                "url": "/assets/030-yoga.png",
                "tint": false
              },
              "action": "https://hdsp.co/share/6839e11d7419d4b1882761d7",
              "backgroundcolor": "#5C7CFA",
              "markcompletedonclick": true
            }
          ]
        },
        {
          "type": "tiles",
          "actions": [
            {
              "text": "More About ACL Recovery",
              "icon": {
                "url": "/assets/025-medicine.png",
                "tint": false
              },
              "action": "https://acltear.info/best-results-acl-reconstruction/",
              "backgroundcolor": "#1A5C2FDA",
              "markcompleted": true
            },
            {
              "text": "Contact",
              "icon": {
                "url": "/assets/support.png",
                "tint": false
              },
              "action": "navpage://Contact",
              "backgroundcolor": "#1A00C2FF"
            }
          ]
        }
      ]
    }
  },
  "settings": {
    "configs": "flow://flows/configs.json"
  },
  "triggers": [
    {
      "id": "trigger_1",
      "type": "random",
      "days": 7,
      "choose": 3,
      "time": "${random_time,15:00}",
      "action": {
        "type": "list",
        "listtype": "random",
        "actions": [
          {
            "type": "notification",
            "survey": true,
            "path": "flow://flows/survey1",
            "expiry": "18:00",
            "title": "Survey Alert!",
            "message": "It's time for your survey1 survey"
          },
          {
            "type": "notification",
            "survey": true,
            "path": "flow://flows/survey2",
            "expiry": "18:00",
            "title": "Survey Alert!",
            "message": "It's time for your survey2 survey"
          },
          {
            "type": "notification",
            "survey": true,
            "path": "flow://flows/survey3",
            "expiry": "18:00",
            "title": "Survey Alert!",
            "message": "It's time for your survey3 survey"
          }
        ]
      }
    },
    {
      "id": "trigger_2",
      "type": "Reminder",
      "threshold": "2.00:00:00",
      "action": {
        "type": "list",
        "listtype": "sequential",
        "actions": [
          {
            "type": "notification",
            "path": "https://hdsp.co/share/681b905c676f43eaa24fb490",
            "title": "Reminder Alert!",
            "message": "We noticed you haven’t completed Meditation Basics in the past couple of days. Please try to fit one in today—just click the mindfulness tile in the app. If you’re having trouble accessing it, let us know so we can help."
          },
          {
            "type": "notification",
            "path": "https://hdsp.co/share/681baa3bb7ef4f17b820ccf6",
            "title": "Reminder Alert!",
            "message": "We noticed you haven’t completed Sports|Recovery Course in the past couple of days. Please try to fit one in today—just click the mindfulness tile in the app. If you’re having trouble accessing it, let us know so we can help."
          },
          {
            "type": "notification",
            "path": "https://hdsp.co/share/6839e11d7419d4b1882761d7",
            "title": "Reminder Alert!",
            "message": "We noticed you haven’t completed Sports|Rehab Course in the past couple of days. Please try to fit one in today—just click the mindfulness tile in the app. If you’re having trouble accessing it, let us know so we can help."
          }
        ]
      }
    }
  ],
  "devices": {
    "device_1": {
      "type": "Oura",
      "connect_title": "Login to Oura",
      "connect_description": "This study requires Oura integration. We are about to send you to Oura to authenticate and then you will be redirected back to our app",
      "android_sync": "deeplink://com.ouraring.oura",
      "ios_sync": "deeplink://Oura://",
      "webhook_data_types": [
        "sleep",
        "workout",
        "daily_activity"
      ],
      "scopes": [
        "daily",
        "workout",
        "sleep",
        "ring_configuration"
      ],
      "jobs": [
        "job_1",
        "job_2"
      ]
    }
  },
  "goals": {
    "goal_1": {
      "device_id": "device_1",
      "data_type": "daily_activity",
      "type": "percentile",
      "field": "active",
      "required_days": 10,
      "percentile": 0.6,
      "show_loading": true
    }
  },
  "jobs": {
    "job_1": {
      "type": "device",
      "service": "Oura",
      "data_type": "daily_activity",
      "days": 1,
      "condition": [
        "non_wear_time",
        ">",
        "36000"
      ],
      "notification_id": "notification_1"
    },
    "job_2": {
      "type": "device",
      "service": "Oura",
      "data_type": "daily_activity",
      "days": 1,
      "condition": [
        "steps",
        "<",
        "2000"
      ],
      "notification_id": "notification_2"
    }
  },
  "notifications": {
    "notification_1": {
      "type": "remote",
      "expiry": "1",
      "title": "Tracker Alert!",
      "message": "Hi! We’ve noticed your tracker hasn’t recorded much data over the past two days. Please try to wear it as much as possible—ideally all day. If it’s not working or you’re having trouble, let us know so we can help.",
      "action": "navpage://Devices"
    },
    "notification_2": {
      "type": "remote",
      "expiry": "1",
      "title": "Tracker Alert!",
      "message": "Hi! Your step count is low, make sure you to walk and stay active.",
      "action": "navpage://Devices"
    }
  }
}
